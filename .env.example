# Google OAuth client configured with the Calendar API enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Supabase backend credentials. Keep the service-role key server-side only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public HTTPS endpoint used by Google Calendar webhook watches.
WEBHOOK_URL=

# Runtime settings.
PORT=3000
LOG_LEVEL=info
